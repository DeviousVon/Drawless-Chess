    <string name="options_title">Opções</string>
    <string name="options_audio">Áudio</string>
    <string name="options_audio_description">Controle os sons físicos do tabuleiro e dos resultados da partida.</string>
    <string name="options_sound_effects">Efeitos sonoros</string>
    <string name="options_sound_effects_description">Reproduza sons de lance, captura, vitória e derrota.</string>
    <string name="options_board">Tabuleiro</string>
    <string name="options_board_description">Escolha as orientações exibidas ao redor e sobre o tabuleiro.</string>
    <string name="options_board_coordinates">Coordenadas do tabuleiro</string>
    <string name="options_board_coordinates_description">Mostre as letras e os números das casas nas bordas do tabuleiro.</string>
    <string name="options_threat_indication">Indicação de ameaças</string>
    <string name="options_threat_indication_description">Destaque suas peças que estão sendo atacadas pelo adversário. Isso é uma ajuda: uma vitória vale 95 em vez de 100 pontos e não se qualifica para partidas ranqueadas. A opção vale para novas partidas; uma partida retomada mantém a configuração com que começou.</string>
    <string name="options_game_feedback">Apresentação da partida</string>
    <string name="options_game_feedback_description">Ajuste a apresentação do resultado sem alterar as regras do xadrez.</string>
    <string name="options_celebration_effects">Efeitos de celebração de vitória ou derrota</string>
    <string name="options_celebration_effects_description">Mostre a animação de vitória ou derrota em tela cheia e reproduza o efeito correspondente de fogos de artifício ou vidro. A opção Efeitos sonoros continua sendo o controle principal do áudio. O resultado e a pontuação são sempre exibidos.</string>
    <string name="options_local_storage_notice">Salvo localmente pelo Drawless Chess e não enviado à BB_Games. O backup do Android pode incluir estas configurações de acordo com os ajustes do seu dispositivo.</string>

