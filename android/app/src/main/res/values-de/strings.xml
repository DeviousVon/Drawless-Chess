    <string name="options_title">Optionen</string>
    <string name="options_audio">Audio</string>
    <string name="options_audio_description">Brett- und Partieergebnisklänge einstellen.</string>
    <string name="options_sound_effects">Soundeffekte</string>
    <string name="options_sound_effects_description">Klänge für Züge, Schläge, Siege und Niederlagen wiedergeben.</string>
    <string name="options_sound_volume">Effektlautstärke</string>
    <string name="options_sound_volume_description">Spielklänge unabhängig von der Gerätelautstärke einstellen.</string>
    <string name="options_board">Brett</string>
    <string name="options_board_description">Lege fest, welche Hilfen am und auf dem Brett angezeigt werden.</string>
    <string name="options_board_coordinates">Brettkoordinaten</string>
    <string name="options_board_coordinates_description">Reihen- und Linienbezeichnungen an den Bretträndern anzeigen.</string>
    <string name="options_threat_indication">Bedrohungsanzeige</string>
    <string name="options_threat_indication_description">Markiert deine Figuren, die vom Gegner angegriffen werden. Dies gilt als Hilfe: Ein Sieg bringt 95 statt 100 Punkte und zählt nicht für gewertete Partien. Die Einstellung gilt für neue Partien; eine fortgesetzte Partie behält ihre ursprüngliche Einstellung.</string>
    <string name="options_game_feedback">Partie-Feedback</string>
    <string name="options_game_feedback_description">Die Ergebnisdarstellung anpassen, ohne die Schachregeln zu ändern.</string>
    <string name="options_haptic_feedback">Haptisches Feedback</string>
    <string name="options_haptic_feedback_description">Dezente Vibrationen begleiten Auswahl, Züge, Schlagzüge, Schachgebote und Partieergebnisse. Die Systemeinstellung für Berührungsfeedback gilt weiterhin.</string>
    <string name="options_celebration_effects">Sieges-/Niederlageneffekte</string>
    <string name="options_celebration_effects_description">Zeigt die bildschirmfüllende Sieges- oder Niederlagenanimation und spielt das passende Feuerwerk- oder Glassignal ab. Die Einstellung „Soundeffekte“ bleibt die zentrale Audiosteuerung. Ergebnis und Punktzahl werden immer angezeigt.</string>
    <string name="options_local_storage_notice">Wird lokal von Drawless Chess gespeichert und nicht an BB_Games gesendet. Je nach Geräteeinstellungen kann die Android-Sicherung diese Einstellungen enthalten.</string>
