    <!-- Opciones -->
    <string name="options_title">Opciones</string>
    <string name="options_audio">Audio</string>
    <string name="options_audio_description">Controla los sonidos del tablero físico y de los resultados.</string>
    <string name="options_sound_effects">Efectos de sonido</string>
    <string name="options_sound_effects_description">Reproduce sonidos de movimiento, captura, victoria y derrota.</string>
    <string name="options_board">Tablero</string>
    <string name="options_board_description">Elige las ayudas que aparecen alrededor y sobre el tablero.</string>
    <string name="options_board_coordinates">Coordenadas del tablero</string>
    <string name="options_board_coordinates_description">Muestra las letras y los números de las casillas en los bordes del tablero.</string>
    <string name="options_threat_indication">Indicación de amenazas</string>
    <string name="options_threat_indication_description">Resalta tus piezas atacadas por el oponente. Esto es una ayuda: una victoria otorga 95 puntos en lugar de 100 y no cumple los requisitos para partidas con clasificación. Se aplica a las partidas nuevas; una partida reanudada conserva el ajuste con el que comenzó.</string>
    <string name="options_game_feedback">Presentación de la partida</string>
    <string name="options_game_feedback_description">Ajusta la presentación del resultado sin cambiar las reglas del ajedrez.</string>
    <string name="options_celebration_effects">Efectos de celebración de victoria o derrota</string>
    <string name="options_celebration_effects_description">Muestra la animación de victoria o derrota en pantalla completa y reproduce los fuegos artificiales o el sonido de cristal correspondiente. El ajuste Efectos de sonido sigue siendo el control principal del audio. El resultado y la puntuación siempre se muestran.</string>
    <string name="options_local_storage_notice">Drawless Chess guarda estos datos localmente y no los envía a BB_Games. Las copias de seguridad de Android pueden incluir estos ajustes según la configuración de tu dispositivo.</string>

